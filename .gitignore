# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-web
dist-ssr
*.local

# Web-mode seed (generated from server/data/scenarios/default by
# scripts/seed-web-defaults.mjs at `npm run build:web`; never committed, never
# in the local build).
/src/runtime/web/generated/

# Vendored Fantasy Map Generator (fetched at runtime by scripts/fetch-fmg.mjs)
/fmg/
server/data/*
!server/data/scenarios/

# Large world-map binaries — hosted as GitHub Release assets and downloaded by
# scripts/fetch-map-assets.mjs, not committed (they used to be in Git LFS, whose
# free bandwidth a few installs exhausted). See scripts/map-assets.json.
/public/assets/*.pmtiles
/public/assets/regions-seed.geojson
/public/assets/cities-seed.json
/server/data/scenarios/default/regions.geojson
.key
CLAUDE.md

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Content-node runtime store (hash-named blobs, populated by scripts/populate-node.mjs)
/node-content/

# Offline root signing PRIVATE key — never commit
/trust/*.key.pem
